library(dplyr)  # For %>% and rename_with
library(stringr)  # For string manipulation
library(exiftoolr)
library(lubridate)  # For timezone handling
# Set the directory paths (replace with actual paths)
aph_directory <- "//net.nefsc.noaa.gov/UAS/Species_Projects/Whales/2024/SEUS/20240111/APH-22"  # Replace with actual path
flight_date_directory <- "//net.nefsc.noaa.gov/UAS/Species_Projects/Whales/2024/SEUS/20240111"  # Replace with actual path
# Initialize warnings vector
warnings <- c()
# Step 1: Find the correct date subdirectory (same as flight_date_directory) inside the APH folder
date_folder <- file.path(aph_directory, basename(flight_date_directory))
print(paste("Date folder:", date_folder))
# Step 2: Navigate to the GPX folder inside the date folder
gpx_directory <- file.path(date_folder, "GPX")
print(paste("GPX folder path:", gpx_directory))
# Step 3: Check if the GPX folder exists
if (!dir.exists(gpx_directory)) {
warnings <- c(warnings, paste("Error: GPX directory missing in APH folder.", gpx_directory))
print(warnings)
} else {
# Step 4: Find .txt files in the GPX folder
trigger_files <- list.files(gpx_directory, pattern = "\\.txt$", full.names = TRUE, ignore.case = TRUE)
print(paste("Trigger files found:", trigger_files))
if (length(trigger_files) == 0) {
warnings <- c(warnings, "Error: No trigger files found in the GPX folder.")
print(warnings)
} else {
# Step 5: Process each trigger file
trigger_data_list <- lapply(trigger_files, function(file) {
print(paste("Processing file:", file))
# Read the file using readLines
data_raw <- readLines(file)
# Use the first line as the header, removing the #
header_line <- sub("^#", "", data_raw[1])
header <- unlist(strsplit(header_line, ";"))
# Remove lines starting with "#"
data_clean <- data_raw[!grepl("^#", data_raw)]
# Convert the cleaned data into a data table
data <- fread(text = data_clean, sep = ";", header = FALSE, col.names = header)
print("Data after reading and cleaning:")
print(head(data))  # Show first few rows of the cleaned data
return(data)
})
# Step 6: Combine trigger files into one data table
combined_trigger_data <- rbindlist(trigger_data_list, fill = TRUE)
combined_trigger_data <- combined_trigger_data %>% rename_with(~ gsub("\\s+", "_", .))
print("Combined trigger data:")
print(head(combined_trigger_data))  # Show first few rows of the combined data
}
}
# Step 7: Check for images in the jpg/JPG or flight# folders
image_directory <- list.files(aph_directory, pattern = "^(jpg|JPG|flight)", full.names = TRUE)
print(paste("Image directory:", image_directory))
# Step 8: List image files
image_files <- list.files(image_directory, pattern = "^P.*\\.JPG$", full.names = TRUE)
print(paste("Image files found:", image_files))
# Step 9: Handle mismatch between trigger rows and image files
if (length(image_files) == 0) {
warnings <- c(warnings, "Warning: No images found in the APH flight.")
print(warnings)
combined_trigger_data$ImageNum <- NA
} else {
# Extract image metadata using exif_read if there's a mismatch
if (length(image_files) != nrow(combined_trigger_data)) {
warnings <- c(warnings, "Warning: Mismatch between the number of trigger file rows and images.")
print(warnings)
# Extract datetimeoriginal from image EXIF metadata
image_metadata <- exif_read(image_files, tags = c("filename", "datetimeoriginal"))
# Step to correctly convert DateTimeOriginal to UTC
image_metadata$DateTimeOriginal <- as.POSIXct(image_metadata$DateTimeOriginal, format = "%Y:%m:%d %H:%M:%S", tz = "America/New_York")
# Convert to UTC
image_metadata$datetime_utc <- with_tz(image_metadata$datetimeoriginal, tzone = "UTC")
# Match image metadata to trigger data based on the closest timestamp
combined_trigger_data$Time <- as.POSIXct(combined_trigger_data$Time, format = "%Y-%m-%dT%H:%M:%OS", tz = "UTC")
# Function to find the closest time match
find_closest_time <- function(image_time, trigger_times) {
time_differences <- abs(difftime(image_time, trigger_times, units = "secs"))
closest_index <- which.min(time_differences)
return(closest_index)
}
# Loop through each image and match it to the closest trigger row
combined_trigger_data$ImageNum <- NA  # Initialize column
for (i in seq_along(image_metadata$datetimeoriginal)) {
closest_row <- find_closest_time(image_metadata$datetimeoriginal[i], combined_trigger_data$Time)
combined_trigger_data$ImageNum[closest_row] <- i  # Assign image number
}
print("Image numbers after matching with EXIF metadata:")
print(head(combined_trigger_data$ImageNum))
} else {
# If no mismatch, extract image numbers directly from filenames
image_nums <- as.numeric(sub("^P(\\d+)\\.JPG$", "\\1", basename(image_files)))
combined_trigger_data$ImageNum <- image_nums
}
}
